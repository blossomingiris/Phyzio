{
  "compilerOptions": {
    "lib": ["ES2020"],

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    "target": "esnext",
    "module": "nodenext",
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",

    "noEmit": true,
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,

    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "paths": {
      "#app/*": ["./*"]
    }
  },
  "include": ["./**/*.ts"]
}
